{
  "name": "uoplan-monorepo",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm run -r test",
    "test:watch": "pnpm --filter web test:watch",
    "prepare": "lefthook install",
    "hooks:install": "lefthook install",
    "hooks:run": "lefthook run pre-commit",
    "scrape:catalogue": "pnpm --filter scrapers scrape:catalogue",
    "scrape:schedules": "pnpm --filter scrapers scrape:schedules",
    "scrape:ratemyprofessors": "pnpm --filter scrapers scrape:ratemyprofessors"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-lingui": "^0.11.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
