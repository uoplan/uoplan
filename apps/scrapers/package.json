{
  "name": "scrapers",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "scrape:catalogue": "node src/scraper.ts",
    "backfill:aliases": "node src/backfillAliases.ts",
    "scrape:schedules": "node src/schedule_scraper.ts",
    "enrich:schedules": "node --experimental-transform-types --experimental-specifier-resolution=node src/enrich_schedules_cli.ts",
    "scrape:ratemyprofessors": "node src/ratemyprofessors_scraper.ts",
    "build:proto": "node --experimental-transform-types --experimental-specifier-resolution=node src/build_proto.ts",
    "check:terms": "node src/check_terms.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "got": "^14.6.6",
    "jsdom": "^28.1.0",
    "p-limit": "^7.3.0",
    "schedule": "workspace:^",
    "tough-cookie": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4.1.0"
  }
