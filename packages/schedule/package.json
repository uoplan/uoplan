{
  "name": "schedule",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate:proto": "protoc --ts_proto_out=./src/proto --proto_path=./proto ./proto/state.proto --ts_proto_opt=esModuleInterop=true,forceLong=long,useOptionals=messages,outputJsonMethods=false,outputPartialMethods=false",
    "generate": "pnpm generate:proto",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "pdfjs-dist": "^5.5.207",
    "schemas": "workspace:*"
  },
  "devDependencies": {
    "protoc": "^34.0.0",
    "ts-proto": "^2.11.6",
    "vitest": "^4.1.0"
  }
}
